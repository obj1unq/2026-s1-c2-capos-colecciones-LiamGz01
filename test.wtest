import capos.*


describe "Rolando" {
    method initialize() {
      rolando.tamañoMochila(2)
    }
  test "Rolando encuentra la espada del destino" {
    rolando.encontrar(espadaDestino)
    assert.that(rolando.mochila().contains(espadaDestino))
  }

  test "Rolando encuentra el libro de hechizos" {
    rolando.encontrar(libroDeHechizos)
    assert.that(rolando.mochila().contains(libroDeHechizos))
  }

  test "Rolando encuentra el collar divino (no lo recolecta, ya que tiene la espada y el libro encima y su capacidad es de 2)" {
    const mochila = #{espadaDestino,libroDeHechizos}
    rolando.encontrar(collarDivino)
    assert.throwsException(rolando.mochila().contains(collarDivino))
    //assert.notThat(rolando.mochila().contains(collarDivino))
  }

  test "Rolando llega al castillo de piedra (deja en el castillo la espada y el libro de hechizos)" {
    rolando.encontrar(espadaDestino)
    rolando.encontrar(libroDeHechizos)
    rolando.llegarAHogar()
    assert.that(castilloPiedra.almacen().contains(espadaDestino))
    assert.that(castilloPiedra.almacen().contains(libroDeHechizos))
    rolando.encontrar(collarDivino)
    rolando.llegarAHogar()
    assert.that(castilloPiedra.almacen().contains(collarDivino))
  }

  test "description" {
    rolando.encontrar(espadaDestino)
    rolando.encontrar(libroDeHechizos)
    assert.throwsException({ rolando.encontrar(collarDivino) })
    rolando.llegarAHogar()
    rolando.encontrar(armaduraAcero)
    rolando.encontrar(collarDivino)
    assert.that(rolando.historia() == [espadaDestino,libroDeHechizos, collarDivino, armaduraAcero,collarDivino])

  }

  test "Comportamiento de los artefactos" {
    rolando.poderBase(5)
    rolando.tamañoMochila(3)
    const mochila = #{espadaDestino, armaduraAcero, collarDivino}
    assert.equals(espadaDestino.poder(), 5)
    assert.equals(armaduraAcero.poder(), 6)
    assert.equals(collarDivino.poder(), 3)
    rolando.batallar()
    assert.equals(espadaDestino.poder(), 2.5)
  }

  test "ejemplo de batalla" {
    
  }
}








describe "Castillo de piedra" {
  test "description" {
    rolando.encontrar(espadaDestino)
    rolando.encontrar(libroDeHechizos)
    assert.throwsException({ rolando.encontrar(collarDivino) })
    rolando.llegarAHogar()
    rolando.encontrar(armaduraAcero)
    rolando.encontrar(collarDivino)
    assert.that(rolando.historia() == [espadaDestino,libroDeHechizos, collarDivino, armaduraAcero,collarDivino])

  }
}